{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "tiktok-feed",
  "title": "TikTok Feed",
  "description": "Monitor TikTok accounts and post new videos to Discord",
  "icon": "icon.png",
  "author": "nishchal",
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "TikTok Feed",
      "description": "Manage TikTok → Discord feed",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2",
    "@raycast/utils": "^1.19.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.4",
    "@types/react": "19.0.8",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
